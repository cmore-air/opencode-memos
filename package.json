{
  "name": "opencode-memos",
  "version": "2.0.1",
  "description": "OpenCode plugin for persistent memory using MemOS",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "opencode-memos": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node && bun build ./src/cli.ts --outfile ./dist/cli.js --target node && tsc --emitDeclarationOnly",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "memos",
    "memory",
    "ai",
    "coding-agent"
  ],
  "author": "Supermemory",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/supermemoryai/opencode-supermemory"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.162"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  },
  "opencode": {
    "type": "plugin",
    "hooks": [
      "chat.message",
      "event",
      "experimental.chat.messages.transform"
    ]
  },
  "files": [
    "dist"
  ]
}
